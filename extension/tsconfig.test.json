{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~lib/*": ["src/lib/*"],
      "~store/*": ["src/store/*"],
      "~components/*": ["src/components/*"],
      "~src/*": ["src/*"]
    }
  },
  "include": ["tests/**/*", "src/**/*"]
}
