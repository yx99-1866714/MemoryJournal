{
  "name": "mysaga",
  "displayName": "My Saga",
  "version": "0.1.0",
  "description": "A memory-powered journaling Chrome extension",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "jest --verbose"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "plasmo": "^0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.304",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.20",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3"
  },
  "manifest": {
    "action": {
      "default_popup": "popup.html"
    },
    "permissions": [
      "storage",
      "sidePanel",
      "alarms",
      "notifications"
    ],
    "host_permissions": [
      "http://localhost:8000/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
