# Database
DATABASE_URL=postgresql+asyncpg://memoryjournal:memoryjournal_dev@localhost:5433/memoryjournal

# JWT Auth
JWT_SECRET=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# EverMemOS (Phase 2 — optional, skipped if empty)
EVERMEMOS_API_URL=https://api.evermind.ai
EVERMEMOS_API_KEY=your-evermemos-api-key

# LLM via OpenRouter (Phase 2 — optional, skipped if empty)
OPENROUTER_API_KEY=your-openrouter-api-key
LLM_MODEL=x-ai/grok-4-fast

# Logging
VERBOSE=false
